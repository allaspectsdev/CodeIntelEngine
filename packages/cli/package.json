{
  "name": "@codeintel/cli",
  "version": "0.1.0",
  "description": "CLI for CodeIntelEngine",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "codeintel": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@codeintel/core": "*",
    "@codeintel/ingestion": "*",
    "@codeintel/query": "*",
    "@codeintel/tools": "*",
    "@codeintel/server": "*",
    "commander": "^13.0.0",
    "chalk": "^5.4.0",
    "ora": "^8.1.0"
  },
  "devDependencies": {
    "vitest": "^3.0.0",
    "typescript": "^5.7.0"
  }
}
